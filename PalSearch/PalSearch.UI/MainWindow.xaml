<Window x:Class="PalSearch.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:PalSearch.UI.Localization"
        xmlns:local="clr-namespace:PalSearch.UI"
        Title="{loc:Loc Key=LC_APP_TITLE}"
        Height="720" Width="1200"
        MinHeight="500" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        SnapsToDevicePixels="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ===== Top Bar ===== -->
        <Border Grid.Row="0" 
                Background="{StaticResource SurfaceBrush}" 
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- App Title -->
                <TextBlock Grid.Column="0" 
                           Text="{loc:Loc Key=LC_APP_TITLE}"
                           FontSize="16" FontWeight="Bold" 
                           Foreground="{StaticResource AccentBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,16,0"/>

                <!-- Save Selector -->
                <TextBlock Grid.Column="1" 
                           Text="{loc:Loc Key=LC_SAVE_SELECT}"
                           VerticalAlignment="Center" 
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,8,0"/>
                <ComboBox Grid.Column="2"
                          ItemsSource="{Binding SaveOptions}"
                          SelectedItem="{Binding SelectedSave}"
                          DisplayMemberPath="DisplayName"
                          MinWidth="200"
                          MaxWidth="350"
                          VerticalAlignment="Center"
                          Margin="0,0,8,0"/>

                <!-- Refresh Button -->
                <Button Grid.Column="3"
                        Command="{Binding RefreshSavesCommand}"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Padding="12,6">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#x21BB;" FontSize="14" Margin="0,0,6,0"/>
                        <TextBlock Text="{loc:Loc Key=LC_SAVE_REFRESH}"/>
                    </StackPanel>
                </Button>

                <!-- Loading Indicator -->
                <ProgressBar Grid.Column="4"
                             IsIndeterminate="{Binding IsLoading}"
                             Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                             Width="120"
                             VerticalAlignment="Center"
                             Margin="0,0,8,0"/>

                <!-- Language Switch Button -->
                <Button Grid.Column="4"
                        Command="{Binding SwitchLanguageCommand}"
                        VerticalAlignment="Center"
                        Padding="10,6"
                        Visibility="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#x1F310;" FontSize="14" Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding SelectedLocale, Converter={StaticResource LocaleDisplayConverter}}"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- ===== Main Content: TabControl ===== -->
        <TabControl Grid.Row="1" 
                    Background="{StaticResource BackgroundBrush}"
                    BorderThickness="0"
                    SelectedIndex="{Binding SelectedTabIndex}">

            <!-- ===== Items Tab ===== -->
            <TabItem>
                <TabItem.Header>
                    <TextBlock Text="{loc:Loc Key=LC_TAB_ITEMS}" FontSize="13"/>
                </TabItem.Header>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Items Search Bar -->
                    <Border Grid.Row="0" 
                            Background="{StaticResource SurfaceBrush}"
                            Padding="12,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" MaxWidth="400"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding ItemSearchText, UpdateSourceTrigger=PropertyChanged}"
                                     VerticalAlignment="Center">
                                <TextBox.Style>
                                    <Style TargetType="{x:Type TextBox}" BasedOn="{StaticResource {x:Type TextBox}}">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="{x:Type TextBox}">
                                                    <Border Background="{TemplateBinding Background}" 
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="4">
                                                        <Grid>
                                                            <TextBlock x:Name="Placeholder"
                                                                       Text="{loc:Loc Key=LC_SEARCH_PLACEHOLDER}"
                                                                       Foreground="{StaticResource TextMutedBrush}"
                                                                       VerticalAlignment="Center"
                                                                       Margin="10,0,0,0"
                                                                       Visibility="Collapsed"/>
                                                            <ScrollViewer x:Name="PART_ContentHost" Margin="10,7,10,7"/>
                                                        </Grid>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="Text" Value="">
                                                            <Setter TargetName="Placeholder" Property="Visibility" Value="Visible"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                            <TextBlock Grid.Column="1" 
                                       VerticalAlignment="Center"
                                       Margin="12,0,0,0"
                                       Foreground="{StaticResource TextSecondaryBrush}">
                                <Run Text="{loc:Loc Key=LC_STATS_TOTAL_ITEMS}"/>
                                <Run Text="{Binding TotalItemCount}"/>
                                <Run Text=" | "/>
                                <Run Text="{loc:Loc Key=LC_STATS_UNIQUE_ITEMS}"/>
                                <Run Text="{Binding UniqueItemCount}"/>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <!-- Items DataGrid -->
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding FilteredItems}"
                              AlternationCount="2"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Extended"
                              SelectionUnit="FullRow">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{loc:Loc Key=LC_ITEM_NAME}" 
                                                Binding="{Binding Name}" 
                                                Width="200"/>
                            <DataGridTextColumn Header="{loc:Loc Key=LC_ITEM_COUNT}" 
                                                Binding="{Binding StackCount}" 
                                                Width="80">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="{x:Type TextBlock}">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="{loc:Loc Key=LC_ITEM_CONTAINER}" 
                                                Binding="{Binding ContainerName}" 
                                                Width="150"/>
                            <DataGridTextColumn Header="{loc:Loc Key=LC_ITEM_BASE}" 
                                                Binding="{Binding BaseName}" 
                                                Width="120"/>
                            <DataGridTextColumn Header="{loc:Loc Key=LC_ITEM_COORDINATES}" 
                                                Binding="{Binding Coordinates}" 
                                                Width="150"/>
                            <DataGridTextColumn Header="Container Type" 
                                                Binding="{Binding ContainerType}" 
                                                Width="130"/>
                            <DataGridTemplateColumn Width="60">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="&#x1F4CD;" 
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontSize="16"
                                                   ToolTip="{Binding LocationTooltip}"
                                                   Cursor="Hand"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ===== Pals Tab ===== -->
            <TabItem>
                <TabItem.Header>
                    <TextBlock Text="{loc:Loc Key=LC_TAB_PALS}" FontSize="13"/>
                </TabItem.Header>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Pals Filter Panel -->
                    <Border Grid.Row="0" 
                            Background="{StaticResource SurfaceBrush}"
                            Padding="12,10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Row 1: Search + Name Filter + Stats -->
                            <Grid Grid.Row="0" Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" MaxWidth="300"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*" MaxWidth="200"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBox Grid.Column="0"
                                         Text="{Binding PalSearchText, UpdateSourceTrigger=PropertyChanged}"
                                         VerticalAlignment="Center">
                                    <TextBox.Style>
                                        <Style TargetType="{x:Type TextBox}" BasedOn="{StaticResource {x:Type TextBox}}">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="{x:Type TextBox}">
                                                        <Border Background="{TemplateBinding Background}" 
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="4">
                                                            <Grid>
                                                                <TextBlock x:Name="Placeholder"
                                                                           Text="{loc:Loc Key=LC_SEARCH_PLACEHOLDER}"
                                                                           Foreground="{StaticResource TextMutedBrush}"
                                                                           VerticalAlignment="Center"
                                                                           Margin="10,0,0,0"
                                                                           Visibility="Collapsed"/>
                                                                <ScrollViewer x:Name="PART_ContentHost" Margin="10,7,10,7"/>
                                                            </Grid>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="Text" Value="">
                                                                <Setter TargetName="Placeholder" Property="Visibility" Value="Visible"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>

                                <Separator Grid.Column="1" 
                                           Style="{StaticResource {x:Type Separator}}" 
                                           Width="1" Margin="12,4"
                                           VerticalAlignment="Stretch"/>

                                <TextBlock Grid.Column="3" 
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right"
                                           Foreground="{StaticResource TextSecondaryBrush}">
                                    <Run Text="{loc:Loc Key=LC_STATS_TOTAL_PALS}"/>
                                    <Run Text="{Binding TotalPalCount}"/>
                                    <Run Text=" | "/>
                                    <Run Text="{loc:Loc Key=LC_STATS_UNIQUE_PALS}"/>
                                    <Run Text="{Binding UniquePalCount}"/>
                                </TextBlock>
                            </Grid>

                            <!-- Row 2: IV Filters + Passive/Active Skill Filters -->
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*" MaxWidth="250"/>
                                    <ColumnDefinition Width="*" MaxWidth="250"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" 
                                           Text="IV" 
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontWeight="SemiBold"
                                           Margin="0,0,8,0"/>

                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                                    <TextBlock Text="{loc:Loc Key=LC_PAL_IV_HP}" 
                                               VerticalAlignment="Center"
                                               FontSize="11"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               Margin="0,0,4,0"/>
                                    <TextBox Text="{Binding MinIvHp, UpdateSourceTrigger=PropertyChanged}" 
                                             Width="40" VerticalAlignment="Center" 
                                             TextAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                                    <TextBlock Text="{loc:Loc Key=LC_PAL_IV_ATTACK}" 
                                               VerticalAlignment="Center"
                                               FontSize="11"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               Margin="0,0,4,0"/>
                                    <TextBox Text="{Binding MinIvAttack, UpdateSourceTrigger=PropertyChanged}" 
                                             Width="40" VerticalAlignment="Center" 
                                             TextAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                                    <TextBlock Text="{loc:Loc Key=LC_PAL_IV_DEFENSE}" 
                                               VerticalAlignment="Center"
                                               FontSize="11"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               Margin="0,0,4,0"/>
                                    <TextBox Text="{Binding MinIvDefense, UpdateSourceTrigger=PropertyChanged}" 
                                             Width="40" VerticalAlignment="Center" 
                                             TextAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="{loc:Loc Key=LC_PAL_PASSIVES}" 
                                               VerticalAlignment="Center"
                                               FontSize="11"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               Margin="0,0,4,0"/>
                                    <TextBox Text="{Binding PassiveSearchText, UpdateSourceTrigger=PropertyChanged}" 
                                             Width="180" VerticalAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="{loc:Loc Key=LC_PAL_ACTIVE_SKILLS}" 
                                               VerticalAlignment="Center"
                                               FontSize="11"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               Margin="0,0,4,0"/>
                                    <TextBox Text="{Binding ActiveSkillSearchText, UpdateSourceTrigger=PropertyChanged}" 
                                             Width="180" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Pals ListView - palcalc Inspired Game-Style Cards -->
                    <ListView Grid.Row="1"
                              ItemsSource="{Binding FilteredPals}"
                              SelectionMode="Extended"
                              VirtualizingPanel.ScrollUnit="Pixel"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              Background="Transparent"
                              BorderThickness="0">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="{x:Type ListViewItem}">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="6,3"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type ListViewItem}">
                                            <Border x:Name="Bd" 
                                                    Background="{TemplateBinding Background}" 
                                                    BorderBrush="#2A3040"
                                                    BorderThickness="1"
                                                    CornerRadius="6"
                                                    Padding="10,8">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#1A2030"/>
                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#425595"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#1E2A3A"/>
                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#5CA8FF"/>
                                                </Trigger>
                                                <MultiTrigger>
                                                    <MultiTrigger.Conditions>
                                                        <Condition Property="IsSelected" Value="True"/>
                                                        <Condition Property="Selector.IsSelectionActive" Value="False"/>
                                                    </MultiTrigger.Conditions>
                                                    <Setter TargetName="Bd" Property="Background" Value="#152028"/>
                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#3A4A60"/>
                                                </MultiTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="220"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Col 0: Pal Icon + Name + Level + Gender + Rank (palcalc-style card header) -->
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                                        <!-- Circular Pal Icon (palcalc-style) -->
                                        <Border Width="44" Height="44" CornerRadius="22"
                                                Background="#1C2124"
                                                BorderBrush="#33383A"
                                                BorderThickness="2"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="&#x1F43E;" FontSize="20"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" 
                                                       FontSize="14" FontWeight="Bold"
                                                       Foreground="#E8ECF0"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxWidth="140"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                <!-- Level Badge (game-style) -->
                                                <Border Background="#2A3A50" 
                                                        CornerRadius="3" Padding="5,1" Margin="0,0,6,0">
                                                    <TextBlock Text="{Binding LevelDisplay}" 
                                                               FontSize="10" FontWeight="SemiBold"
                                                               Foreground="#8AB4F8"/>
                                                </Border>
                                                <!-- Gender -->
                                                <Border Background="{Binding Gender, Converter={StaticResource GenderColorConverter}}"
                                                        CornerRadius="3" Padding="3,1" Margin="0,0,6,0">
                                                    <TextBlock Text="{Binding GenderIcon}" 
                                                               FontSize="10" FontWeight="Bold"
                                                               Foreground="White"/>
                                                </Border>
                                                <!-- Rank Stars -->
                                                <ItemsControl ItemsSource="{Binding RankStars}" Margin="0,0,4,0">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Orientation="Horizontal"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="&#x2B50;" FontSize="9" Margin="0,0,1,0"/>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Col 1: IV Bars (palcalc-style compact) -->
                                    <Grid Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="28"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="28"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- HP Bar -->
                                        <TextBlock Grid.Row="0" Grid.Column="0" 
                                                   Text="HP" FontSize="9" FontWeight="SemiBold"
                                                   Foreground="#4CAF50"
                                                   VerticalAlignment="Center"/>
                                        <Border Grid.Row="0" Grid.Column="1" 
                                                Background="#1A2520" CornerRadius="2" 
                                                Height="6" Margin="4,1">
                                            <Border Background="#4CAF50" CornerRadius="2" 
                                                    HorizontalAlignment="Left"
                                                    Width="{Binding IvHpPercent, Converter={StaticResource PercentToWidthConverter}, ConverterParameter=100}"/>
                                        </Border>
                                        <TextBlock Grid.Row="0" Grid.Column="2" 
                                                   Text="{Binding IV_HP}" FontSize="9"
                                                   Foreground="#8A9AA8"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>

                                        <!-- ATK Bar -->
                                        <TextBlock Grid.Row="1" Grid.Column="0" 
                                                   Text="ATK" FontSize="9" FontWeight="SemiBold"
                                                   Foreground="#FF9800"
                                                   VerticalAlignment="Center"/>
                                        <Border Grid.Row="1" Grid.Column="1" 
                                                Background="#251E10" CornerRadius="2" 
                                                Height="6" Margin="4,1">
                                            <Border Background="#FF9800" CornerRadius="2" 
                                                    HorizontalAlignment="Left"
                                                    Width="{Binding IvAttackPercent, Converter={StaticResource PercentToWidthConverter}, ConverterParameter=100}"/>
                                        </Border>
                                        <TextBlock Grid.Row="1" Grid.Column="2" 
                                                   Text="{Binding IV_Attack}" FontSize="9"
                                                   Foreground="#8A9AA8"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>

                                        <!-- DEF Bar -->
                                        <TextBlock Grid.Row="2" Grid.Column="0" 
                                                   Text="DEF" FontSize="9" FontWeight="SemiBold"
                                                   Foreground="#2196F3"
                                                   VerticalAlignment="Center"/>
                                        <Border Grid.Row="2" Grid.Column="1" 
                                                Background="#101E28" CornerRadius="2" 
                                                Height="6" Margin="4,1">
                                            <Border Background="#2196F3" CornerRadius="2" 
                                                    HorizontalAlignment="Left"
                                                    Width="{Binding IvDefensePercent, Converter={StaticResource PercentToWidthConverter}, ConverterParameter=100}"/>
                                        </Border>
                                        <TextBlock Grid.Row="2" Grid.Column="2" 
                                                   Text="{Binding IV_Defense}" FontSize="9"
                                                   Foreground="#8A9AA8"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>

                                    <!-- Col 2: Passive Skills + Active Skills -->
                                    <StackPanel Grid.Column="2" Margin="12,0,0,0" VerticalAlignment="Center">
                                        <!-- Passive Skills -->
                                        <ItemsControl ItemsSource="{Binding PassiveList}" Margin="0,0,0,2">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#1A2A40" 
                                                            BorderBrush="#3A5A80"
                                                            BorderThickness="1"
                                                            CornerRadius="3" 
                                                            Padding="5,2" Margin="0,0,4,2">
                                                        <TextBlock Text="{Binding}" FontSize="10"
                                                                   Foreground="#8AB4F8"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <!-- Active Skills -->
                                        <ItemsControl ItemsSource="{Binding ActiveSkillList}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#1C2124" 
                                                            BorderBrush="#2A3040"
                                                            BorderThickness="1"
                                                            CornerRadius="3" 
                                                            Padding="5,2" Margin="0,0,4,2">
                                                        <TextBlock Text="{Binding}" FontSize="10"
                                                                   Foreground="#7A8A98"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>

                                    <!-- Col 3: Owner + Location -->
                                    <StackPanel Grid.Column="3" 
                                                VerticalAlignment="Center" 
                                                Margin="8,0,0,0"
                                                MinWidth="80">
                                        <TextBlock Text="{Binding OwnerName}" 
                                                   FontSize="11" 
                                                   Foreground="#8A9AA8"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxWidth="100"/>
                                        <TextBlock Text="{Binding LocationType}" 
                                                   FontSize="10" 
                                                   Foreground="#5A6A78"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxWidth="100"/>
                                    </StackPanel>

                                    <!-- Col 4: Location Button with palcalc-style Palbox Grid Tooltip -->
                                    <Button Grid.Column="4" 
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Center"
                                            Width="36" Height="36"
                                            Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"
                                            Cursor="Hand"
                                            ToolTipService.InitialShowDelay="200"
                                            ToolTipService.ShowDuration="30000">
                                        <Button.ToolTip>
                                            <ToolTip Background="#0A1520" 
                                                     BorderBrush="#2A3A50" 
                                                     BorderThickness="1"
                                                     Padding="0">
                                                <StackPanel>
                                                    <!-- Location Info Header -->
                                                    <Border Background="#0D1A28" Padding="10,8" 
                                                            BorderBrush="#2A3A50" BorderThickness="0,0,0,1">
                                                        <StackPanel>
                                                            <TextBlock Text="&#x1F4CD; Location Info" 
                                                                       FontSize="13" FontWeight="Bold"
                                                                       Foreground="#8AB4F8" Margin="0,0,0,4"/>
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto"/>
                                                                    <RowDefinition Height="Auto"/>
                                                                    <RowDefinition Height="Auto"/>
                                                                </Grid.RowDefinitions>
                                                                <TextBlock Grid.Row="0" Grid.Column="0" 
                                                                           Text="Type:" FontSize="11"
                                                                           Foreground="#5A6A78" Margin="0,0,8,0"/>
                                                                <TextBlock Grid.Row="0" Grid.Column="1" 
                                                                           Text="{Binding LocationType}" FontSize="11"
                                                                           Foreground="#C8D0D8"/>
                                                                <TextBlock Grid.Row="1" Grid.Column="0" 
                                                                           Text="Owner:" FontSize="11"
                                                                           Foreground="#5A6A78" Margin="0,0,8,0"/>
                                                                <TextBlock Grid.Row="1" Grid.Column="1" 
                                                                           Text="{Binding OwnerName}" FontSize="11"
                                                                           Foreground="#C8D0D8"/>
                                                                <TextBlock Grid.Row="2" Grid.Column="0" 
                                                                           Text="Position:" FontSize="11"
                                                                           Foreground="#5A6A78" Margin="0,0,8,0"/>
                                                                <TextBlock Grid.Row="2" Grid.Column="1" 
                                                                           Text="{Binding DisplayCoord}" FontSize="11"
                                                                           Foreground="#C8D0D8"/>
                                                            </Grid>
                                                        </StackPanel>
                                                    </Border>

                                                    <!-- Palbox Storage Grid (palcalc-style) -->
                                                    <Border Padding="10,8"
                                                            Visibility="{Binding HasPalboxPosition, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                        <StackPanel>
                                                            <!-- Tab Header -->
                                                            <Border Background="#1A2A40" 
                                                                    CornerRadius="4" 
                                                                    Padding="6,3" 
                                                                    Margin="0,0,0,8"
                                                                    HorizontalAlignment="Center">
                                                                <TextBlock FontSize="12" FontWeight="Bold" 
                                                                           Foreground="#8AB4F8">
                                                                    <Run Text="&#x1F4E6; Palbox Tab "/>
                                                                    <Run Text="{Binding PalboxTab}"/>
                                                                </TextBlock>
                                                            </Border>

                                                            <!-- Grid Info -->
                                                            <TextBlock FontSize="10" 
                                                                       Foreground="#5A6A78" 
                                                                       TextAlignment="Center"
                                                                       Margin="0,0,0,6">
                                                                <Run Text="Row "/>
                                                                <Run Text="{Binding PalboxRow}" FontWeight="Bold" Foreground="#C8D0D8"/>
                                                                <Run Text="  Col "/>
                                                                <Run Text="{Binding PalboxCol}" FontWeight="Bold" Foreground="#C8D0D8"/>
                                                            </TextBlock>

                                                            <!-- 5x6 Palbox Grid (palcalc ContainerGridView style) -->
                                                            <Border Background="#040F15" 
                                                                    CornerRadius="6" 
                                                                    Padding="4"
                                                                    BorderBrush="#1A2530"
                                                                    BorderThickness="1">
                                                                <Viewbox Width="200" Height="240" StretchDirection="DownOnly">
                                                                    <Grid>
                                                                        <Grid.Resources>
                                                                            <Style x:Key="PalboxSlotStyle" TargetType="{x:Type Border}">
                                                                                <Setter Property="Width" Value="36"/>
                                                                                <Setter Property="Height" Value="36"/>
                                                                                <Setter Property="CornerRadius" Value="18"/>
                                                                                <Setter Property="Background" Value="#1C2124"/>
                                                                                <Setter Property="BorderBrush" Value="#33383A"/>
                                                                                <Setter Property="BorderThickness" Value="2"/>
                                                                                <Setter Property="Margin" Value="2"/>
                                                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                                            </Style>
                                                                        </Grid.Resources>

                                                                        <Grid.RowDefinitions>
                                                                            <RowDefinition Height="Auto"/>
                                                                            <RowDefinition Height="Auto"/>
                                                                            <RowDefinition Height="Auto"/>
                                                                            <RowDefinition Height="Auto"/>
                                                                            <RowDefinition Height="Auto"/>
                                                                            <RowDefinition Height="Auto"/>
                                                                        </Grid.RowDefinitions>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                        </Grid.ColumnDefinitions>

                                                                        <!-- Row 0 -->
                                                                        <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource PalboxSlotStyle}"/>
                                                                        <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource PalboxSlotStyle}"/>
                                                                        <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource PalboxSlotStyle}"/>
                                                                        <Border Grid.Row="0" Grid.Column="3" Style="{StaticResource PalboxSlotStyle}"/>
                                                                        <Border Grid.Row="0" Grid.Column="4" Style="{StaticResource PalboxSlotStyle}"/>
                                                                        <!-- Row 1 -->
                                                                        <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource PalboxSlotStyle}"/>
                                                                        <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource PalboxSlotStyle}"/>
                                                                        <Border Grid.Row="1" Grid.Column="2" Style="{StaticResource PalboxSlotStyle}"/>
                                                                        <Border Grid.Row="1" Grid.Column="3" Style="{StaticResource PalboxSlotStyle}"/>
                                                                        <Border Grid.Row="1" Grid.Column="4" Style="{StaticResource PalboxSlotStyle}"/>
                                                                        <!-- Row 2 -->
                                                                        <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource PalboxSlotStyle}"/>
                                                                        <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource PalboxSlotStyle}"/>
                                                                        <Border Grid.Row="2" Grid.Column="2" Style="{StaticResource PalboxSlotStyle}"/>
                                                                        <Border Grid.Row="2" Grid.Column="3" Style="{StaticResource PalboxSlotStyle}"/>
                                                                        <Border Grid.Row="2" Grid.Column="4" Style="{StaticResource PalboxSlotStyle}"/>
                                                                        <!-- Row 3 -->
                                                                        <Border Grid.Row="3" Grid.Column="0" Style="{StaticResource PalboxSlotStyle}"/>
                                                                        <Border Grid.Row="3" Grid.Column="1" Style="{StaticResource PalboxSlotStyle}"/>
                                                                        <Border Grid.Row="3" Grid.Column="2" Style="{StaticResource PalboxSlotStyle}"/>
                                                                        <Border Grid.Row="3" Grid.Column="3" Style="{StaticResource PalboxSlotStyle}"/>
                                                                        <Border Grid.Row="3" Grid.Column="4" Style="{StaticResource PalboxSlotStyle}"/>
                                                                        <!-- Row 4 -->
                                                                        <Border Grid.Row="4" Grid.Column="0" Style="{StaticResource PalboxSlotStyle}"/>
                                                                        <Border Grid.Row="4" Grid.Column="1" Style="{StaticResource PalboxSlotStyle}"/>
                                                                        <Border Grid.Row="4" Grid.Column="2" Style="{StaticResource PalboxSlotStyle}"/>
                                                                        <Border Grid.Row="4" Grid.Column="3" Style="{StaticResource PalboxSlotStyle}"/>
                                                                        <Border Grid.Row="4" Grid.Column="4" Style="{StaticResource PalboxSlotStyle}"/>
                                                                        <!-- Row 5 -->
                                                                        <Border Grid.Row="5" Grid.Column="0" Style="{StaticResource PalboxSlotStyle}"/>
                                                                        <Border Grid.Row="5" Grid.Column="1" Style="{StaticResource PalboxSlotStyle}"/>
                                                                        <Border Grid.Row="5" Grid.Column="2" Style="{StaticResource PalboxSlotStyle}"/>
                                                                        <Border Grid.Row="5" Grid.Column="3" Style="{StaticResource PalboxSlotStyle}"/>
                                                                        <Border Grid.Row="5" Grid.Column="4" Style="{StaticResource PalboxSlotStyle}"/>
                                                                    </Grid>
                                                                </Viewbox>
                                                            </Border>
                                                        </StackPanel>
                                                    </Border>

                                                    <!-- Non-palbox location info -->
                                                    <Border Padding="10,8"
                                                            Visibility="{Binding HasPalboxPosition, Converter={StaticResource InverseBooleanConverter}}">
                                                        <TextBlock Text="{Binding LocationType}" 
                                                                   FontSize="11" Foreground="#8A9AA8"
                                                                   TextWrapping="Wrap"/>
                                                    </Border>
                                                </StackPanel>
                                            </ToolTip>
                                        </Button.ToolTip>
                                        <TextBlock Text="&#x1F4CD;" FontSize="16"/>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- ===== Status Bar ===== -->
        <Border Grid.Row="2" 
                Background="{StaticResource StatusBarBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" 
                           Text="{Binding StatusText}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center"
                           FontSize="12"/>

                <TextBlock Grid.Column="1" 
                           VerticalAlignment="Center"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="11">
                    <Run Text="PalSearch "/>
                    <Run Text="{x:Static local:App.Version}"/>
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</Window>